# ═══════════════════════════════════════════════════════════════
# PerspectiveOS — Environment Variables
# Copy to .env.local for local dev. Set all in Vercel dashboard for prod.
# ═══════════════════════════════════════════════════════════════

# ── AI / LLM (required for Perspective Engine) ───────────────────────────────
# Google AI Studio — FREE, no credit card required
# Register: https://aistudio.google.com/apikey
# Limits: Flash 10 RPM / 250 RPD | Flash-Lite 15 RPM / 1000 RPD | Embed 1500 RPD
GEMINI_API_KEY=AIzaSyDzDlKcR0NW2buSsZBo--UnTGiFZPmfYrE

# Groq — FREE fallback LLM, 14,400 req/day
# Register: https://console.groq.com
# Uses: llama-3.3-70b-versatile when Gemini is rate-limited
GROQ_API_KEY=gsk_...

# ── Cache (strongly recommended) ─────────────────────────────────────────────
# Upstash Redis — FREE 10,000 commands/day
# Register: https://upstash.com → Create serverless Redis database
# Critical: prevents duplicate Gemini calls, keeps you inside free limits
UPSTASH_REDIS_REST_URL=https://social-viper-50294.upstash.io
UPSTASH_REDIS_REST_TOKEN=AsR2AAIgcDEvZIcS6HmcH1WrTtqxz9SDqFkEEQJ3Ca3PLjV_Uj7PEw

# ── Conflict Data ─────────────────────────────────────────────────────────────
# ACLED — FREE for academic/non-commercial use
# Register: https://acleddata.com/register/ → create myACLED account
# Auth: OAuth2 — token fetched at runtime (valid 24h, cached in Redis)
# New API (May 2025): https://acleddata.com/api-documentation/getting-started
ACLED_EMAIL=tarek.roukos@lau.edu
ACLED_PASSWORD=your_acleddata_account_password

# NASA FIRMS — FREE fire detection satellite data
# Register: https://firms.modaps.eosdis.nasa.gov/api/
NASA_FIRMS_KEY=xxx...
NASA_FIRMS_MAP_KEY=9eb337a327788ec9c41e6316eaa8a0f4
# https://firms.modaps.eosdis.nasa.gov/api/area/
# https://firms.modaps.eosdis.nasa.gov/api/

# ── Flight / Ship Tracking (optional) ────────────────────────────────────────
# OpenSky Network — FREE with account (higher rate limits)
# Register: https://opensky-network.org/
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# AISStream — FREE 1 connection for ship tracking
# Register: https://aisstream.io/
AISSTREAM_API_KEY=

# ── GDELT (no key needed — completely free) ───────────────────────────────────
# https://api.gdeltproject.org — no registration, no limits
# Used for: conflict events, tone divergence, topic intelligence

# ═══════════════════════════════════════════════════════════════
# OPTIONAL (paid but cheap) — add later for production
# ═══════════════════════════════════════════════════════════════

# NewsAPI.org — $49/mo for prod, free for dev (100 req/day)
# Adds: keyword search across 80K sources
# NEWSAPI_KEY=

# Aviation Stack — free 100 req/mo for flight data
# AVIATIONSTACK_API=

# Cloudflare Radar — free with CF account for internet outage data
# CF_RADAR_TOKEN=

# Finnhub — free 60 req/min for financial markets
# FINNHUB_API_KEY=

# Polymarket (no key needed) — prediction markets for geopolitical events
# https://gamma-api.polymarket.com — public API
