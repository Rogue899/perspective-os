{
  "name": "perspectiveos",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node dev-server.mjs & vite",
    "dev:api": "node dev-server.mjs",
    "dev:vercel": "vercel dev",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "tasks:list": "node scripts/task-queue.mjs list",
    "tasks:next": "node scripts/task-queue.mjs next --agent copilot",
    "tasks:next:claude": "node scripts/task-queue.mjs next --agent claude",
    "tasks:done": "node scripts/task-queue.mjs done",
    "tasks:add": "node scripts/task-queue.mjs add",
    "tasks:note": "node scripts/task-queue.mjs note",
    "tasks:block": "node scripts/task-queue.mjs block",
    "tasks:release": "node scripts/task-queue.mjs release",
    "tasks:sync": "node scripts/task-queue.mjs sync",
    "tasks:loop": "node scripts/task-loop.mjs --agent copilot --work \"\" --test \"npm run typecheck; npm run build\"",
    "tasks:loop:claude": "node scripts/task-loop.mjs --agent claude --work \"\" --test \"npm run typecheck; npm run build\"",
    "tasks:loop:ux": "node scripts/task-loop.mjs --agent copilot --work \"\" --test \"npm run typecheck; npm run build; node tmp-smoke-playwright.mjs\"",
    "tasks:loop:ux:claude": "node scripts/task-loop.mjs --agent claude --work \"\" --test \"npm run typecheck; npm run build; node tmp-smoke-playwright.mjs\"",
    "tasks:loop:dry": "node scripts/task-loop.mjs --agent copilot --dry-run --max 1"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "@xenova/transformers": "^2.17.2",
    "idb": "^8.0.0",
    "lucide-react": "^0.577.0",
    "maplibre-gl": "^4.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
